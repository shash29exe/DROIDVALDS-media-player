# libvorbis pkg-config source file

prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: vorbis
Description: vorbis is the primary Ogg Vorbis library
Version: @VERSION@
Conflicts:
Libs:  -L${libdir} -lvorbis  @VORBIS_LIBS@
Cflags:  -I${includedir} 
Requires:   ogg
