msgid "Hardware decoding"
msgstr "бһҖбһ¶бһҡвҖӢбһҢбһ·бһҖбһјбһҠвҖӢбһ•бҹ’бһ“бҹӮбһҖвҖӢбһҡбһ№бһ„"

