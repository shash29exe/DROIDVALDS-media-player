msgstr "бһҖбһ¶бһҡбһ–бһ¶бһҡвҖӢбһҖбҹҶбһ–бһјбһӣ"

#: src/libvlc-module.c:227
msgid "Protect against sound clipping"
msgstr "бһҖбһ¶бһҡбһ–бһ¶бһҡвҖӢбһ–бһёвҖӢбһҖбһ¶бһҡвҖӢбһҖбһ¶бһҸбҹӢвҖӢбһҹбҹҶбһЎбҹҒбһ„"

